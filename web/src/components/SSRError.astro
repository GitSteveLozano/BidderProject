---
interface Props {
  page: string;
  error: unknown;
}

const { page, error } = Astro.props;
const message =
  error instanceof Error
    ? `${error.name}: ${error.message}`
    : typeof error === 'string'
      ? error
      : (() => {
          try {
            return JSON.stringify(error, null, 2);
          } catch {
            return String(error);
          }
        })();
const stack = error instanceof Error ? error.stack : null;
---

<div class="rounded-md border border-red-300 bg-red-50 p-6 my-6">
  <h2 class="text-lg font-semibold text-red-900">
    Page render failed: {page}
  </h2>
  <p class="mt-2 text-sm text-red-800">
    Something threw while server-rendering this page on the Cloudflare
    Functions runtime. Check the same issue at <a
      href="/api/health"
      class="underline font-medium"
    >/api/health</a> — it surfaces env vars + Supabase + the
    <code class="bg-red-100 px-1 rounded text-xs">nodejs_compat</code>
    flag without secrets.
  </p>
  <div class="mt-4 rounded bg-red-100 p-3 text-xs font-mono text-red-900 overflow-x-auto">
    <strong>{message}</strong>
  </div>
  {stack && (
    <details class="mt-3">
      <summary class="cursor-pointer text-xs text-red-700">Stack</summary>
      <pre class="mt-2 text-xs text-red-900 overflow-x-auto whitespace-pre-wrap">{stack}</pre>
    </details>
  )}
</div>
