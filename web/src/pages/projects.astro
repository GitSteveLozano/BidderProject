---
import Brief from '@/layouts/Brief.astro';
import MultiUpload from '@/components/projects/MultiUpload';
import { client as supabaseService } from '@/lib/supabase';
import { listProjects } from '@/lib/projects';

export const prerender = false;
Astro.response.headers.set('cache-control', 'no-store, no-cache, must-revalidate, max-age=0');

const env = Astro.locals.runtime?.env;
const user = Astro.locals.user;
const membership = Astro.locals.membership;
if (!user || !membership || !env) {
  return Astro.redirect('/auth/signin?next=/projects');
}

const svc = supabaseService(env, 'service');
const projects = await listProjects(svc, membership.shop_id, { limit: 200 });

const { data: shop } = await svc
  .from('shops')
  .select('legal_name, trade_name, owner_name, data_state')
  .eq('id', membership.shop_id)
  .maybeSingle();
const shopLabel = shop?.trade_name || shop?.legal_name || 'My shop';
const ownerFirst = (shop?.owner_name ?? user.name ?? user.email ?? '').split(' ')[0];

const STATUS_LABEL: Record<string, string> = {
  intake: 'Intake',
  scoped: 'Scoped',
  quoted: 'Quoted',
  won: 'Won',
  lost: 'Lost',
  in_progress: 'In progress',
  done: 'Done',
};
---

<Brief
  title="Projects"
  active="projects"
  shopLabel={shopLabel}
  shopInitial={shopLabel.charAt(0).toUpperCase()}
  ownerFirst={ownerFirst}
  ownerRole={(membership.role.charAt(0).toUpperCase() + membership.role.slice(1)) as 'Owner' | 'Admin' | 'Member'}
  dataState={shop?.data_state ?? 'cold-start'}
>
  <div class="mb-8">
    <div class="text-eyebrow font-mono uppercase text-[color:var(--color-muted-2)] mb-1.5">Projects</div>
    <h1 class="font-serif text-[36px] font-medium leading-tight tracking-tight">
      One job, one place.
    </h1>
    <p class="mt-3 text-[15px] font-serif text-[color:var(--color-ink-2)] leading-relaxed max-w-[55ch]">
      Plans, selections, vendor invoices, scoping threads — group everything related to one
      address under a project. Brief reads them and helps you draft the quote from the
      inputs.
    </p>
  </div>

  <section class="mb-10">
    <h2 class="font-serif text-[20px] font-medium mb-3">Drop new files</h2>
    <MultiUpload client:load onComplete={() => window.location.reload()} />
  </section>

  <section>
    <h2 class="font-serif text-[20px] font-medium mb-3">
      All projects {projects.length > 0 && (<span class="text-[14px] font-mono text-[color:var(--color-muted-2)] ml-2">{projects.length}</span>)}
    </h2>
    {projects.length === 0 ? (
      <div class="rounded-xl border border-dashed border-[color:var(--color-line-2)] bg-[color:var(--color-surface-2)] px-6 py-10 text-center">
        <p class="font-serif italic text-[color:var(--color-muted)]">
          No projects yet. Drop a few files above and Brief will group them.
        </p>
      </div>
    ) : (
      <ul class="space-y-2">
        {projects.map((p: any) => (
          <li>
            <a
              href={`/projects/${p.id}`}
              class="block rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] px-5 py-4 hover:border-[color:var(--color-line-2)]"
            >
              <div class="flex items-baseline justify-between gap-4">
                <div class="min-w-0">
                  <div class="font-serif text-[17px] font-medium truncate">{p.name}</div>
                  {p.address && (
                    <div class="text-[12.5px] font-mono text-[color:var(--color-muted)] mt-0.5">
                      {p.address}
                    </div>
                  )}
                </div>
                <div class="text-right shrink-0">
                  <span class="text-[10.5px] font-mono uppercase tracking-wide text-[color:var(--color-accent)] bg-[color:var(--color-accent-tint,#fbe9d4)] px-1.5 py-0.5 rounded-sm">
                    {STATUS_LABEL[p.status] ?? p.status}
                  </span>
                  <div class="text-[11px] font-mono text-[color:var(--color-muted-2)] mt-1">
                    {new Date(p.updated_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                  </div>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Brief>
