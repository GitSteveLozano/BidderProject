---
import Brief from '@/layouts/Brief.astro';
import StatusPill from '@/components/ui/StatusPill';
import Pill from '@/components/ui/Pill';
import { client as supabaseService } from '@/lib/supabase';
import { fmtCurrencyCompact, fmtRelativeDate } from '@/lib/quote-helpers';

export const prerender = false;
Astro.response.headers.set('cache-control', 'no-store, no-cache, must-revalidate, max-age=0');
Astro.response.headers.set('cdn-cache-control', 'no-store');

const env = Astro.locals.runtime?.env;
const user = Astro.locals.user;
const membership = Astro.locals.membership;
if (!user || !membership || !env) {
  return Astro.redirect('/auth/signin?next=/clients');
}

const svc = supabaseService(env, 'service');
const { data: shop } = await svc
  .from('shops')
  .select('legal_name, trade_name, owner_name, data_state')
  .eq('id', membership.shop_id)
  .maybeSingle();

const { data: clients } = await svc
  .from('clients')
  .select('id, name, type, primary_contact_name, total_quoted, total_won, win_rate_pct, last_activity_at')
  .eq('shop_id', membership.shop_id)
  .order('last_activity_at', { ascending: false, nullsFirst: false });

const shopLabel = shop?.trade_name || shop?.legal_name || 'My shop';
const ownerFirst = (shop?.owner_name ?? user.name ?? user.email ?? '').split(' ')[0];
const rows = clients ?? [];
---

<Brief
  title="Clients"
  active="clients"
  shopLabel={shopLabel}
  shopInitial={shopLabel.charAt(0).toUpperCase()}
  ownerFirst={ownerFirst}
  ownerRole={membership.role.charAt(0).toUpperCase() + membership.role.slice(1)}
  dataState={shop?.data_state ?? 'cold-start'}
>
  <div class="text-eyebrow font-mono uppercase text-[color:var(--color-muted-2)] mb-1">
    Client book
  </div>
  <h1 class="font-serif text-[28px] font-medium leading-tight">
    People you bid for.
  </h1>

  {rows.length === 0 ? (
    <div class="mt-12 mx-auto max-w-[480px] text-center px-6">
      <div class="text-eyebrow font-mono uppercase text-[color:var(--color-muted-2)] mb-2">
        Cold start
      </div>
      <h2 class="font-serif text-[24px] font-medium leading-tight">
        Clients are added automatically.
      </h2>
      <p class="mt-3 text-sm text-[color:var(--color-muted)] leading-relaxed">
        The first quote you send creates the first client. You don't have to enter anyone manually unless you want to.
      </p>
      <div class="mt-6">
        <a
          href="/generate"
          class="inline-flex items-center px-4 py-2 rounded-lg bg-[color:var(--color-accent)] text-[color:var(--color-accent-ink)] text-sm font-medium hover:brightness-95"
        >
          Produce your first quote →
        </a>
      </div>
    </div>
  ) : (
    <div class="mt-6 rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] overflow-hidden">
      <table class="w-full">
        <thead class="bg-[color:var(--color-surface-2)]">
          <tr>
            <th class="px-3.5 py-3 text-left text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">Client</th>
            <th class="px-3.5 py-3 text-left text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">Type</th>
            <th class="px-3.5 py-3 text-right text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">Quoted</th>
            <th class="px-3.5 py-3 text-right text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">Won</th>
            <th class="px-3.5 py-3 text-right text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">Win rate</th>
            <th class="px-3.5 py-3 text-right text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">Last activity</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((c) => (
            <tr class="border-t border-[color:var(--color-line)] hover:bg-[color:var(--color-surface-2)]">
              <td class="px-3.5 py-3 text-sm">
                <div class="font-medium">{c.name}</div>
                {c.primary_contact_name && (
                  <div class="text-xs text-[color:var(--color-muted)] mt-0.5">{c.primary_contact_name}</div>
                )}
              </td>
              <td class="px-3.5 py-3">
                {c.type && (
                  <Pill tone="neutral" dot={false} size="sm">
                    {c.type === 'gc' ? 'GC' : c.type.charAt(0).toUpperCase() + c.type.slice(1)}
                  </Pill>
                )}
              </td>
              <td class="px-3.5 py-3 text-right text-sm font-mono tabular-nums">
                {fmtCurrencyCompact(Number(c.total_quoted ?? 0))}
              </td>
              <td class="px-3.5 py-3 text-right text-sm font-mono tabular-nums">
                {fmtCurrencyCompact(Number(c.total_won ?? 0))}
              </td>
              <td class="px-3.5 py-3 text-right text-sm font-mono tabular-nums">
                {c.win_rate_pct != null ? `${Number(c.win_rate_pct).toFixed(0)}%` : '—'}
              </td>
              <td class="px-3.5 py-3 text-right text-xs text-[color:var(--color-muted)] font-mono">
                {fmtRelativeDate(c.last_activity_at)}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</Brief>
