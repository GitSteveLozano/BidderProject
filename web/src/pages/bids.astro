---
import Base from '@/layouts/Base.astro';
import SSRError from '@/components/SSRError.astro';
import { client as supabaseClient, getCompanies } from '@/lib/supabase';

export const prerender = false;

// Personalized SSR responses must not be edge-cached. Set per-page
// because the previous middleware-based approach broke /bids et al
// (commit 9efe16d reverted it). The cdn-cache-control header targets
// Cloudflare specifically; cache-control covers browsers.
Astro.response.headers.set('cache-control', 'no-store, no-cache, must-revalidate, max-age=0');
Astro.response.headers.set('cdn-cache-control', 'no-store');

// Permanent diagnostic. Bumped whenever the SSR-on-Cloudflare contract
// changes so we can spot a regression at a glance via /bids?diag=1.
const SSR_BUILD_TAG = 'streaming-disabled-postbuild';
Astro.response.headers.set('x-ssr-build-tag', SSR_BUILD_TAG);

// Diagnostic short-circuit: /bids?diag=1 returns a JSON dump of the
// runtime detection booleans Astro uses to pick rendering strategy.
// Kept as a long-lived probe so an @astrojs/cloudflare or Workers
// runtime change can't silently regress us back to the [object Object]
// failure mode. Root cause: on Workers with nodejs_compat,
// Object.prototype.toString.call(process) === "[object process]", so
// Astro's isNode=true → renderToAsyncIterable → Response coerces to
// "[object Object]". We force streaming=false post-build to dodge it.
if (Astro.url.searchParams.get('diag') === '1') {
  const procTag =
    typeof process !== 'undefined'
      ? Object.prototype.toString.call(process)
      : '(undefined)';
  const isNodeLike =
    typeof process !== 'undefined' && procTag === '[object process]';
  const diag = {
    build_tag: SSR_BUILD_TAG,
    timestamp: new Date().toISOString(),
    runtime: {
      typeof_process: typeof process,
      typeof_Deno: typeof (globalThis as any).Deno,
      process_toString_tag: procTag,
      astro_isNode_would_be: isNodeLike,
      has_ReadableStream: typeof ReadableStream !== 'undefined',
      has_TextEncoder: typeof TextEncoder !== 'undefined',
      navigator_userAgent: (globalThis as any).navigator?.userAgent ?? null,
    },
  };
  return new Response(JSON.stringify(diag, null, 2), {
    status: 200,
    headers: {
      'content-type': 'application/json',
      'cache-control': 'no-store',
      'x-ssr-build-tag': SSR_BUILD_TAG,
    },
  });
}

let renderError: unknown = null;
let companies: Awaited<ReturnType<typeof getCompanies>> = [];
let companyId: string | undefined;
let bids: any[] = [];

try {
  const env = Astro.locals.runtime?.env;
  companies = await getCompanies(env);
  companyId = Astro.url.searchParams.get('company_id') ?? companies[0]?.id;
  if (env && companyId) {
    const sb = supabaseClient(env, 'service');
    const { data, error } = await sb
      .from('bids')
      .select('id, client_name, service_line, state, outcome, estimated_value, delivered_margin_pct, created_at')
      .eq('company_id', companyId)
      .order('created_at', { ascending: false })
      .limit(50);
    if (error) throw error;
    bids = data ?? [];
  }
} catch (e) {
  renderError = e;
}
---

<Base title="Bids · ProService Bid Intelligence">
  {renderError && <SSRError page="/bids" error={renderError} />}
  <section class="py-6">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-semibold tracking-tight">Bids</h1>
      <select
        class="rounded-md border border-ink-300 bg-white px-3 py-1.5 text-sm"
        onchange="window.location.search = `?company_id=${this.value}`"
      >
        {companies.map((c) => (
          <option value={c.id} selected={c.id === companyId}>
            {c.name}
          </option>
        ))}
      </select>
    </div>
  </section>

  <section class="mt-4">
    {bids.length === 0 ? (
      <div class="rounded-md border border-ink-200 bg-white p-8 text-center">
        <p class="text-ink-600">
          No bids yet. {' '}
          <a href="/generate" class="text-accent-600 font-medium underline">
            Generate your first bid →
          </a>
        </p>
      </div>
    ) : (
      <div class="overflow-x-auto rounded-md border border-ink-200 bg-white">
        <table class="w-full text-sm">
          <thead class="bg-ink-50 text-left">
            <tr>
              <th class="px-3 py-2 font-medium">Client</th>
              <th class="px-3 py-2 font-medium">Service line</th>
              <th class="px-3 py-2 font-medium">State</th>
              <th class="px-3 py-2 font-medium text-right">Value</th>
              <th class="px-3 py-2 font-medium text-right">Margin</th>
              <th class="px-3 py-2 font-medium">Outcome</th>
            </tr>
          </thead>
          <tbody>
            {bids.map((b) => (
              <tr class="border-t border-ink-100 hover:bg-ink-50">
                <td class="px-3 py-2">{b.client_name}</td>
                <td class="px-3 py-2">
                  <code class="text-xs">{b.service_line}</code>
                </td>
                <td class="px-3 py-2">
                  <span class="rounded bg-ink-100 px-2 py-0.5 text-xs">
                    {b.state}
                  </span>
                </td>
                <td class="px-3 py-2 text-right font-mono">
                  ${Number(b.estimated_value ?? 0).toLocaleString()}
                </td>
                <td class="px-3 py-2 text-right font-mono">
                  {b.delivered_margin_pct != null
                    ? `${Number(b.delivered_margin_pct).toFixed(1)}%`
                    : '—'}
                </td>
                <td class="px-3 py-2">{b.outcome ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </section>
</Base>
