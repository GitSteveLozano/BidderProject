---
/**
 * /bids → /quotes redirect.
 *
 * The route is renamed in v1 (per design copy + URL consistency with
 * /quotes/[id]). Leave the redirect in place indefinitely — any
 * external bookmarks / Cloudflare cache pin points still resolve.
 *
 * Carries through the diagnostic ?diag=1 probe to /quotes?diag=1 so
 * the SSR build-tag regression tripwire stays reachable.
 */
export const prerender = false;

const target = new URL(Astro.request.url);
target.pathname = '/quotes';
return Astro.redirect(target.pathname + target.search, 301);
---
