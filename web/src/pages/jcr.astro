---
import Base from '@/layouts/Base.astro';
import { client as supabaseClient, getCompanies } from '@/lib/supabase';

export const prerender = false;

const env = Astro.locals.runtime?.env;
const companies = await getCompanies(env);
const companyId = Astro.url.searchParams.get('company_id') ?? companies[0]?.id;

let rows: any[] = [];
let stats = { count: 0, avgMargin: 0, avgLaborVar: 0 };
if (env && companyId) {
  try {
    const sb = supabaseClient(env, 'anon');
    const { data } = await sb
      .from('job_cost_reconciliation')
      .select(`
        bid_id, quoted_price, quoted_labor_hours, actual_labor_hours,
        actual_labor_cost, actual_material_cost, actual_other_costs,
        delivered_margin_pct, variance_labor_hours_pct,
        variance_total_cost_pct, reconciled_at,
        bids:bid_id(client_name, service_line)
      `)
      .eq('company_id', companyId)
      .order('reconciled_at', { ascending: false })
      .limit(100);
    rows = data ?? [];
    if (rows.length > 0) {
      stats.count = rows.length;
      stats.avgMargin =
        rows.reduce((s, r) => s + Number(r.delivered_margin_pct ?? 0), 0) / rows.length;
      stats.avgLaborVar =
        rows.reduce((s, r) => s + Number(r.variance_labor_hours_pct ?? 0), 0) /
        rows.length;
    }
  } catch (e) {
    console.warn('JCR fetch failed', e);
  }
}
---

<Base title="Job-Cost Reconciliation · ProService Bid Intelligence">
  <section class="py-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-semibold tracking-tight">
          Job-Cost Reconciliation
        </h1>
        <p class="mt-2 text-ink-600 max-w-2xl">
          Quoted vs actual via ProService payroll. Layer 4 of the spec —
          the closed loop that compounds with every reconciled job.
        </p>
      </div>
      <select
        class="rounded-md border border-ink-300 bg-white px-3 py-1.5 text-sm"
        onchange="window.location.search = `?company_id=${this.value}`"
      >
        {companies.map((c) => (
          <option value={c.id} selected={c.id === companyId}>
            {c.name}
          </option>
        ))}
      </select>
    </div>
  </section>

  {rows.length === 0 ? (
    <div class="rounded-md border border-ink-200 bg-white p-8 text-center">
      <p class="text-ink-600">No reconciled jobs yet for this company.</p>
    </div>
  ) : (
    <>
      <section class="mt-4 grid gap-4 md:grid-cols-3">
        <div class="rounded-md border border-ink-200 bg-white p-5">
          <div class="text-xs font-medium text-ink-500">Reconciled jobs</div>
          <div class="mt-1 text-2xl font-mono font-semibold">{stats.count}</div>
        </div>
        <div class="rounded-md border border-ink-200 bg-white p-5">
          <div class="text-xs font-medium text-ink-500">Avg delivered margin</div>
          <div class="mt-1 text-2xl font-mono font-semibold">
            {stats.avgMargin.toFixed(1)}%
          </div>
        </div>
        <div class="rounded-md border border-ink-200 bg-white p-5">
          <div class="text-xs font-medium text-ink-500">Avg labor variance</div>
          <div class="mt-1 text-2xl font-mono font-semibold">
            {stats.avgLaborVar > 0 ? '+' : ''}
            {stats.avgLaborVar.toFixed(1)}%
          </div>
        </div>
      </section>

      <section class="mt-6 overflow-x-auto rounded-md border border-ink-200 bg-white">
        <table class="w-full text-sm">
          <thead class="bg-ink-50 text-left">
            <tr>
              <th class="px-3 py-2 font-medium">Client</th>
              <th class="px-3 py-2 font-medium">Service line</th>
              <th class="px-3 py-2 font-medium text-right">Quoted</th>
              <th class="px-3 py-2 font-medium text-right">Actual hrs</th>
              <th class="px-3 py-2 font-medium text-right">Labor var</th>
              <th class="px-3 py-2 font-medium text-right">Delivered margin</th>
              <th class="px-3 py-2 font-medium">Reconciled</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((r) => (
              <tr class="border-t border-ink-100 hover:bg-ink-50">
                <td class="px-3 py-2">{r.bids?.client_name ?? '—'}</td>
                <td class="px-3 py-2">
                  <code class="text-xs">{r.bids?.service_line ?? '—'}</code>
                </td>
                <td class="px-3 py-2 text-right font-mono">
                  ${Number(r.quoted_price ?? 0).toLocaleString()}
                </td>
                <td class="px-3 py-2 text-right font-mono">
                  {r.actual_labor_hours ?? '—'}
                </td>
                <td class={`px-3 py-2 text-right font-mono ${
                  Number(r.variance_labor_hours_pct) > 5
                    ? 'text-amber-700'
                    : Number(r.variance_labor_hours_pct) < -5
                      ? 'text-green-700'
                      : ''
                }`}>
                  {Number(r.variance_labor_hours_pct ?? 0) > 0 ? '+' : ''}
                  {Number(r.variance_labor_hours_pct ?? 0).toFixed(1)}%
                </td>
                <td class="px-3 py-2 text-right font-mono">
                  {Number(r.delivered_margin_pct ?? 0).toFixed(1)}%
                </td>
                <td class="px-3 py-2 text-xs text-ink-500">
                  {r.reconciled_at ? new Date(r.reconciled_at).toLocaleDateString() : '—'}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    </>
  )}
</Base>
