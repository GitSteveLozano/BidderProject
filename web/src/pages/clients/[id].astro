---
/**
 * GET /clients/[id] — deep view of a single client.
 *
 * Header: name + segment + total-relationship-value + last-activity.
 * Two-column body: left has quotes-history table + jobs strip + notes
 * field; right rail has contact card + relationship KPIs (win rate,
 * average margin, average quote-to-sign days) + recent activity feed.
 */
import Brief from '@/layouts/Brief.astro';
import StatusPill from '@/components/ui/StatusPill';
import Pill from '@/components/ui/Pill';
import ClientNotes from '@/components/clients/ClientNotes';
import ContactsList from '@/components/clients/ContactsList';
import { client as supabaseService } from '@/lib/supabase';
import { fmtCurrencyFull, fmtCurrencyCompact, fmtRelativeDate } from '@/lib/quote-helpers';

export const prerender = false;
Astro.response.headers.set('cache-control', 'no-store, no-cache, must-revalidate, max-age=0');

const env = Astro.locals.runtime?.env;
const user = Astro.locals.user;
const membership = Astro.locals.membership;
if (!user || !membership || !env) {
  return Astro.redirect('/auth/signin?next=' + encodeURIComponent(Astro.url.pathname));
}

const id = Astro.params.id;
if (!id) return Astro.redirect('/clients');

const svc = supabaseService(env, 'service');
const { data: client } = await svc
  .from('clients')
  .select('*')
  .eq('id', id)
  .eq('shop_id', membership.shop_id)
  .maybeSingle();
if (!client) return Astro.redirect('/clients?error=not-found');

const { data: quotes } = await svc
  .from('quotes')
  .select('id, ref, project_title, state, total, margin_pct, sent_at, responded_at, created_at')
  .eq('client_id', id)
  .order('created_at', { ascending: false });

const { data: jobs } = await svc
  .from('jobs')
  .select('id, ref, project_title, state, estimated_total, actual_total, variance_pct, scheduled_start, scheduled_end')
  .eq('client_id', id)
  .order('scheduled_start', { ascending: false, nullsFirst: false });

const { data: events } = await svc
  .from('events')
  .select('id, type, actor, payload, created_at, quote_id, job_id')
  .eq('shop_id', membership.shop_id)
  .in('quote_id', (quotes ?? []).map((q: any) => q.id))
  .order('created_at', { ascending: false })
  .limit(40);

const { data: contacts } = await svc
  .from('client_contacts')
  .select('id, client_id, name, email, phone, title, is_primary, always_notify')
  .eq('client_id', id)
  .order('is_primary', { ascending: false })
  .order('created_at', { ascending: true });

const { data: shop } = await svc
  .from('shops')
  .select('legal_name, trade_name, owner_name, data_state')
  .eq('id', membership.shop_id)
  .maybeSingle();
const shopLabel = shop?.trade_name || shop?.legal_name || 'My shop';
const ownerFirst = (shop?.owner_name ?? user.name ?? user.email ?? '').split(' ')[0];

const qs = quotes ?? [];
const js = jobs ?? [];
const won = qs.filter((q: any) => q.state === 'WON');
const lost = qs.filter((q: any) => q.state === 'LOST');
const winRate = won.length + lost.length >= 3 ? Math.round((won.length / (won.length + lost.length)) * 100) : null;
const avgMargin = won.length
  ? won.reduce((s: number, q: any) => s + Number(q.margin_pct ?? 0), 0) / won.length
  : null;

function daysBetween(a: string | null, b: string | null): number | null {
  if (!a || !b) return null;
  const ms = new Date(b).getTime() - new Date(a).getTime();
  if (ms < 0) return null;
  return ms / (24 * 60 * 60 * 1000);
}
const signTimes = won
  .map((q: any) => daysBetween(q.sent_at, q.responded_at))
  .filter((d: number | null): d is number => d !== null);
const avgDays = signTimes.length ? signTimes.reduce((s, d) => s + d, 0) / signTimes.length : null;

const relationshipLabel =
  qs.length >= 4 ? 'Repeat' : qs.length >= 2 ? 'Returning' : 'New';

const segmentLabel =
  client.type === 'residential' ? 'Residential' :
  client.type === 'commercial' ? 'Commercial' :
  client.type === 'gc' ? 'GC' :
  client.type === 'public' ? 'Public' : null;

const eventLabels: Record<string, string> = {
  'quote.sent': 'Sent',
  'quote.opened': 'Opened',
  'quote.responded': 'Responded',
  'nudge.sent': 'Nudge sent',
  'quote.won': 'Marked won',
  'quote.lost': 'Marked lost',
};
---

<Brief
  title={client.name}
  active="clients"
  shopLabel={shopLabel}
  shopInitial={shopLabel.charAt(0).toUpperCase()}
  ownerFirst={ownerFirst}
  ownerRole={membership.role.charAt(0).toUpperCase() + membership.role.slice(1)}
  dataState={shop?.data_state ?? 'cold-start'}
>
  <a href="/clients" class="text-sm text-[color:var(--color-muted)] hover:text-[color:var(--color-ink)] inline-flex items-center gap-1">
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7.5 2.5L3.5 6l4 3.5" /></svg>
    Back to <span class="font-medium ml-0.5">clients</span>
  </a>

  <div class="mt-4 flex flex-wrap items-baseline gap-x-3 gap-y-1">
    <Pill tone={relationshipLabel === 'Repeat' ? 'accent' : relationshipLabel === 'Returning' ? 'info' : 'neutral'} size="sm">{relationshipLabel}</Pill>
    {segmentLabel && (
      <span class="text-[12.5px] italic font-serif text-[color:var(--color-muted)]">{segmentLabel}</span>
    )}
    <div class="flex-1" />
    <div class="text-right">
      <div class="text-eyebrow font-mono uppercase text-[color:var(--color-muted-2)]">Lifetime</div>
      <div class="font-serif text-[26px] font-medium tabular-nums leading-none mt-0.5">
        {fmtCurrencyCompact(Number(client.total_won ?? 0))}
      </div>
      <div class="text-[12px] text-[color:var(--color-muted)] mt-1 font-mono">
        {fmtCurrencyCompact(Number(client.total_quoted ?? 0))} quoted
      </div>
    </div>
  </div>

  <h1 class="mt-3 font-serif text-[32px] font-medium leading-tight">{client.name}</h1>
  {client.primary_contact_name && (
    <p class="mt-1 text-[15px] font-serif italic text-[color:var(--color-muted)]">
      Primary contact: {client.primary_contact_name}
    </p>
  )}

  <div class="mt-6 grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-8">
    <div>
      <!-- Quotes history -->
      <div class="rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] overflow-hidden">
        <div class="px-5 py-3.5 border-b border-[color:var(--color-line)] flex items-center gap-2.5">
          <h3 class="font-serif text-base font-medium flex-1">Quotes — {qs.length}</h3>
          <a
            href={`/generate?client_id=${client.id}`}
            class="text-xs text-[color:var(--color-accent)] hover:brightness-95 inline-flex items-center gap-1"
          >
            New quote
            <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true"><path d="M2 5.5h7M6 2l3.5 3.5L6 9" /></svg>
          </a>
        </div>
        {qs.length === 0 ? (
          <p class="px-5 py-6 text-sm italic font-serif text-[color:var(--color-muted)]">No quotes yet.</p>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full min-w-[560px]">
              <thead class="bg-[color:var(--color-surface-2)]">
                <tr>
                  <th class="px-3.5 py-2.5 text-left text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">Ref</th>
                  <th class="px-3.5 py-2.5 text-left text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">Project</th>
                  <th class="px-3.5 py-2.5 text-left text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">State</th>
                  <th class="px-3.5 py-2.5 text-right text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">Total</th>
                  <th class="px-3.5 py-2.5 text-right text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">When</th>
                </tr>
              </thead>
              <tbody>
                {qs.map((q: any) => (
                  <tr class="border-t border-[color:var(--color-line)] hover:bg-[color:var(--color-surface-2)]">
                    <td class="px-3.5 py-2.5 font-mono text-[12px] text-[color:var(--color-muted)]">
                      <a href={`/quotes/${q.id}`} class="hover:text-[color:var(--color-ink)] hover:underline">{q.ref}</a>
                    </td>
                    <td class="px-3.5 py-2.5 text-sm">
                      <a href={`/quotes/${q.id}`} class="hover:underline">{q.project_title}</a>
                    </td>
                    <td class="px-3.5 py-2.5"><StatusPill state={q.state} size="sm" /></td>
                    <td class="px-3.5 py-2.5 text-right text-sm font-mono tabular-nums">{fmtCurrencyFull(Number(q.total))}</td>
                    <td class="px-3.5 py-2.5 text-right text-xs font-mono text-[color:var(--color-muted)]">
                      {fmtRelativeDate(q.sent_at ?? q.created_at)}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

      <!-- Jobs strip -->
      {js.length > 0 && (
        <div class="mt-6 rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] overflow-hidden">
          <div class="px-5 py-3.5 border-b border-[color:var(--color-line)]">
            <h3 class="font-serif text-base font-medium">Jobs — {js.length}</h3>
          </div>
          <ul class="divide-y divide-[color:var(--color-line)]">
            {js.map((j: any) => (
              <li class="px-5 py-3 flex items-center gap-3 hover:bg-[color:var(--color-surface-2)]">
                <StatusPill state={j.state} size="sm" />
                <span class="font-mono text-[12px] text-[color:var(--color-muted-2)]">{j.ref}</span>
                <a href={`/jobs#${j.id}`} class="text-sm flex-1 hover:underline">{j.project_title}</a>
                <span class="text-xs font-mono tabular-nums text-[color:var(--color-muted)]">
                  {fmtCurrencyCompact(Number(j.estimated_total ?? 0))}
                </span>
                {j.variance_pct != null && (
                  <span class={[
                    'text-xs font-mono tabular-nums',
                    Number(j.variance_pct) < 0
                      ? 'text-[color:var(--color-good)]'
                      : Number(j.variance_pct) > 20
                        ? 'text-[color:var(--color-danger)]'
                        : Number(j.variance_pct) > 5
                          ? 'text-[color:var(--color-warn)]'
                          : 'text-[color:var(--color-muted)]',
                  ].join(' ')}>
                    {Number(j.variance_pct) >= 0 ? '+' : '−'}{Math.abs(Number(j.variance_pct)).toFixed(0)}%
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Notes (editable) -->
      <div class="mt-6 rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] p-5">
        <div class="text-eyebrow font-mono uppercase text-[color:var(--color-muted)] mb-2">Notes</div>
        <ClientNotes client:load client_id={client.id} initial={client.notes ?? ''} />
      </div>
    </div>

    <aside class="space-y-6">
      <!-- Contacts — multi-contact CRUD. Existing clients with a
           primary_contact on the clients row see a one-click "Add as
           contact" prompt so the legacy info isn't lost. -->
      <div class="rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] p-5">
        <h3 class="text-eyebrow font-mono uppercase text-[color:var(--color-muted)] mb-3">Contacts</h3>
        <ContactsList
          client:load
          client_id={client.id}
          initial={contacts ?? []}
          legacy_primary={
            (contacts ?? []).length === 0 && (client.primary_contact_name || client.primary_contact_email || client.primary_contact_phone)
              ? {
                  name: client.primary_contact_name,
                  email: client.primary_contact_email,
                  phone: client.primary_contact_phone,
                }
              : null
          }
        />
        {(client.address_line || client.city || client.state_code) && (
          <div class="mt-5 pt-4 border-t border-[color:var(--color-line)] text-sm">
            <div class="text-xs text-[color:var(--color-muted)]">Address</div>
            <div class="mt-0.5 font-serif text-[14px] text-[color:var(--color-ink-2)] leading-snug">
              {[client.address_line, [client.city, client.state_code].filter(Boolean).join(', ')].filter(Boolean).join('\n').split('\n').map((line: string) => <div>{line}</div>)}
            </div>
          </div>
        )}
      </div>

      <!-- Relationship KPIs -->
      <div class="rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] p-5">
        <h3 class="text-eyebrow font-mono uppercase text-[color:var(--color-muted)] mb-3">Relationship</h3>
        <dl class="space-y-3 text-sm">
          <div class="flex items-baseline justify-between gap-3">
            <dt class="text-[color:var(--color-muted)]">Win rate</dt>
            <dd class="font-serif text-[18px] font-medium tabular-nums">
              {winRate != null ? `${winRate}%` : '—'}
            </dd>
          </div>
          <div class="flex items-baseline justify-between gap-3">
            <dt class="text-[color:var(--color-muted)]">Avg margin</dt>
            <dd class="font-serif text-[18px] font-medium tabular-nums">
              {avgMargin != null ? `${avgMargin.toFixed(0)}%` : '—'}
            </dd>
          </div>
          <div class="flex items-baseline justify-between gap-3">
            <dt class="text-[color:var(--color-muted)]">Quote→sign</dt>
            <dd class="font-serif text-[18px] font-medium tabular-nums">
              {avgDays != null ? `${avgDays.toFixed(1)}d` : '—'}
            </dd>
          </div>
          <div class="flex items-baseline justify-between gap-3 pt-2 border-t border-[color:var(--color-line)]">
            <dt class="text-[color:var(--color-muted)]">Last activity</dt>
            <dd class="font-mono text-xs">
              {client.last_activity_at ? fmtRelativeDate(client.last_activity_at) : '—'}
            </dd>
          </div>
        </dl>
      </div>

      <!-- Activity feed -->
      <div class="rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] p-5">
        <h3 class="text-eyebrow font-mono uppercase text-[color:var(--color-muted)] mb-3">Activity</h3>
        {(events ?? []).length === 0 ? (
          <p class="text-sm italic font-serif text-[color:var(--color-muted)]">Nothing logged yet.</p>
        ) : (
          <ol class="space-y-3">
            {(events ?? []).slice(0, 12).map((e: any) => (
              <li class="flex items-start gap-3 text-sm">
                <div class="mt-2 w-1.5 h-1.5 rounded-full bg-[color:var(--color-accent)] shrink-0" aria-hidden="true" />
                <div class="flex-1 min-w-0">
                  <div>{eventLabels[e.type] ?? e.type}</div>
                  <time datetime={e.created_at} class="text-xs text-[color:var(--color-muted)] mt-0.5 block">
                    {fmtRelativeDate(e.created_at)}
                  </time>
                </div>
              </li>
            ))}
          </ol>
        )}
      </div>
    </aside>
  </div>
</Brief>
