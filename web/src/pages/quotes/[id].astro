---
import Brief from '@/layouts/Brief.astro';
import StatusPill from '@/components/ui/StatusPill';
import LineItemsTable from '@/components/quotes/LineItemsTable';
import LogReplyButton from '@/components/quotes/LogReplyButton';
import MarkOutcomeButtons from '@/components/quotes/MarkOutcomeButtons';
import QuotePostmortem from '@/components/quotes/QuotePostmortem';
import QuoteReplyDrawer from '@/components/quotes/QuoteReplyDrawer';
import { client as supabaseService } from '@/lib/supabase';
import { fmtCurrencyFull, fmtRelativeDate } from '@/lib/quote-helpers';

export const prerender = false;
Astro.response.headers.set('cache-control', 'no-store, no-cache, must-revalidate, max-age=0');
Astro.response.headers.set('cdn-cache-control', 'no-store');

const env = Astro.locals.runtime?.env;
const user = Astro.locals.user;
const membership = Astro.locals.membership;
if (!user || !membership || !env) {
  return Astro.redirect('/auth/signin?next=' + encodeURIComponent(Astro.url.pathname));
}

const id = Astro.params.id;
if (!id) return Astro.redirect('/quotes');

const svc = supabaseService(env, 'service');
const { data: quote } = await svc
  .from('quotes')
  .select('*, quote_line_items(id, position, description, qty, unit, unit_price, subtotal, category, confidence)')
  .eq('id', id)
  .eq('shop_id', membership.shop_id)
  .maybeSingle();

if (!quote) return Astro.redirect('/quotes?error=not-found');

const { data: events } = await svc
  .from('events')
  .select('id, type, actor, payload, created_at')
  .eq('quote_id', id)
  .order('created_at', { ascending: false })
  .limit(50);

const { data: messages } = await svc
  .from('quote_messages')
  .select('*')
  .eq('quote_id', id)
  .order('created_at', { ascending: false })
  .limit(20);

const lineItems = (quote.quote_line_items ?? []).sort((a: any, b: any) => a.position - b.position);

const { data: shop } = await svc
  .from('shops')
  .select('legal_name, trade_name, owner_name, data_state')
  .eq('id', membership.shop_id)
  .maybeSingle();
const shopLabel = shop?.trade_name || shop?.legal_name || 'My shop';
const ownerFirst = (shop?.owner_name ?? user.name ?? user.email ?? '').split(' ')[0];

const eventLabels: Record<string, string> = {
  'quote.sent': 'Sent',
  'quote.opened': 'Opened',
  'quote.responded': 'Client responded',
  'nudge.sent': 'Nudge sent',
  'quote.won': 'Marked won',
  'quote.lost': 'Marked lost',
};

// Build the AgendaQuote shape the drawer expects.
const ageDays = (() => {
  const ref = quote.sent_at ?? quote.created_at;
  if (!ref) return 0;
  return Math.max(0, Math.floor((Date.now() - new Date(ref).getTime()) / 86_400_000));
})();
const agendaQuote = {
  id: quote.id as string,
  ref: quote.ref as string,
  client_name: quote.client_name as string,
  project_title: quote.project_title as string,
  state: quote.state as 'DRAFT' | 'SENT' | 'AWAITING' | 'RESPONDED' | 'WON' | 'LOST',
  total: Number(quote.total ?? 0),
  next_step: (quote.next_step as string | null) ?? null,
  age_days: ageDays,
  sent_at: quote.sent_at as string | null,
  responded_at: quote.responded_at as string | null,
  created_at: quote.created_at as string,
};

// Most recent inbound message — feeds Reply mode's "client wrote" block.
const lastInbound = (messages ?? []).find((m: any) => m.direction === 'inbound');
const inboundForDrawer = lastInbound
  ? {
      sender:
        (lastInbound.sender_name as string) ||
        (lastInbound.sender_email as string) ||
        (quote.client_contact_name as string) ||
        (quote.client_name as string),
      sent_at: new Date(lastInbound.created_at as string).toLocaleString(),
      body: (lastInbound.body as string) || '',
    }
  : undefined;
---

<Brief
  title={`${quote.client_name} · ${quote.ref}`}
  active="quotedetail"
  shopLabel={shopLabel}
  shopInitial={shopLabel.charAt(0).toUpperCase()}
  ownerFirst={ownerFirst}
  ownerRole={membership.role.charAt(0).toUpperCase() + membership.role.slice(1)}
  dataState={shop?.data_state ?? 'cold-start'}
>
  <a href="/quotes" class="text-sm text-[color:var(--color-muted)] hover:text-[color:var(--color-ink)] inline-flex items-center gap-1">
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7.5 2.5L3.5 6l4 3.5" /></svg>
    Back to <span class="font-medium ml-0.5">quotes</span>
  </a>

  <div class="mt-4 grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-8">
    <div>
      {/* Header row — ref + status + relationship | right-aligned total + margin + likely */}
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
        <span class="font-mono text-[12px] tracking-[0.06em] text-[color:var(--color-muted)]">{quote.ref}</span>
        <StatusPill state={quote.state} size="sm" />
        {quote.relationship && (
          <span class="text-[13px] italic font-serif text-[color:var(--color-muted)]">
            · {quote.relationship} client
          </span>
        )}
        <div class="flex-1" />
        <div class="text-right">
          <div class="text-eyebrow font-mono uppercase text-[color:var(--color-muted-2)]">Total</div>
          <div class="font-serif text-[28px] font-medium tabular-nums leading-none mt-0.5">
            {fmtCurrencyFull(Number(quote.total))}
          </div>
          {quote.margin_pct != null && (
            <div class="text-[12px] text-[color:var(--color-muted)] mt-1 font-mono">
              {Number(quote.margin_pct).toFixed(0)}% margin
            </div>
          )}
        </div>
      </div>

      <h1 class="mt-3 font-serif text-[32px] font-medium leading-tight">
        {quote.client_name}
      </h1>
      <p class="mt-1 text-[15px] font-serif text-[color:var(--color-ink-2)]">
        {quote.project_title}
      </p>

      <!-- Contact + location + sent meta strip -->
      <div class="mt-2 flex flex-wrap gap-4 text-[12.5px] text-[color:var(--color-muted)]">
        {quote.project_address && (
          <span class="inline-flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
              <path d="M6 11s4-3.5 4-7a4 4 0 1 0 -8 0c0 3.5 4 7 4 7z" />
              <circle cx="6" cy="4" r="1.4" />
            </svg>
            {quote.project_address}
          </span>
        )}
        {quote.client_contact_name && (
          <span class="inline-flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
              <rect x="1.5" y="2.5" width="9" height="7" rx="1" />
              <path d="M1.5 3.5l4.5 3 4.5-3" />
            </svg>
            {quote.client_contact_name}
          </span>
        )}
        {quote.sent_at && (
          <span class="inline-flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
              <rect x="1.5" y="2.5" width="9" height="8" rx="1" />
              <path d="M1.5 5h9M4 1.5v2M8 1.5v2" />
            </svg>
            Sent {new Date(quote.sent_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
          </span>
        )}
      </div>

      <!-- Primary action under header (only for live states) -->
      {(['SENT','AWAITING','RESPONDED'] as const).includes(quote.state) && (
        <div class="mt-4 flex items-center gap-2">
          <a
            href={`/quotes/${quote.id}#reply`}
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-[color:var(--color-accent)] text-[color:var(--color-accent-ink)] text-[13px] font-medium hover:brightness-95"
          >
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M2 1.5l8.5 4-3.5 1.6-1.6 3.4-3.4-9z" />
            </svg>
            {quote.state === 'RESPONDED' ? 'Reply to client' : 'Send reminder'}
          </a>
          <LogReplyButton
            client:load
            quote_id={quote.id}
            default_subject={`Re: ${quote.project_title}`}
          />
          <span class="flex-1" />
          <MarkOutcomeButtons client:load quote_id={quote.id} state={quote.state} />
        </div>
      )}

      {quote.scope_summary && (
        <div class="mt-6 rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] p-5">
          <div class="text-eyebrow font-mono uppercase text-[color:var(--color-muted)] mb-2">Scope</div>
          <p class="font-serif text-[15px] leading-relaxed text-[color:var(--color-ink-2)]">
            {quote.scope_summary}
          </p>
        </div>
      )}

      {quote.state === 'LOST' && (
        <div class="mt-6">
          <QuotePostmortem client:load quote_id={quote.id} />
        </div>
      )}

      {/* Body — branches by pricing_structure. Itemized keeps the
          existing editable LineItemsTable (it's the most-used path
          and stays inline-editable for DRAFT quotes). The others
          render read-only summaries — the wizard is still the place
          to actually edit them. */}
      <div class="mt-6">
        {quote.pricing_structure === 'phase_priced' && Array.isArray(quote.phases) && quote.phases.length > 0 ? (
          <div class="rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] overflow-hidden">
            <div class="px-4 py-3 border-b border-[color:var(--color-line)] flex justify-between items-baseline">
              <div class="text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">
                Phases &amp; deliverables
              </div>
              <span class="text-[11px] font-mono text-[color:var(--color-muted-2)]">
                {(quote.phases as any[]).length} phase{(quote.phases as any[]).length === 1 ? '' : 's'}
              </span>
            </div>
            <ul class="divide-y divide-[color:var(--color-line)]">
              {(quote.phases as any[]).map((ph: any, idx: number) => (
                <li class="px-4 py-3 grid grid-cols-[40px_1fr_120px_140px] gap-3 items-baseline text-sm">
                  <span class="font-mono text-[11px] text-[color:var(--color-muted-2)]">{String(idx + 1).padStart(2, '0')}</span>
                  <div>
                    <div class="font-medium">{ph.name}</div>
                    {Array.isArray(ph.deliverables) && ph.deliverables.length > 0 && (
                      <ul class="mt-1 ml-0 pl-4 text-[12.5px] text-[color:var(--color-muted)] list-disc font-serif">
                        {ph.deliverables.map((d: string) => <li>{d}</li>)}
                      </ul>
                    )}
                  </div>
                  <div class="text-right font-mono text-[12.5px] text-[color:var(--color-muted)]">{ph.duration ?? ''}</div>
                  <div class="text-right font-mono tabular-nums">{ph.fee != null ? `$${Number(ph.fee).toLocaleString()}` : '—'}</div>
                </li>
              ))}
            </ul>
            <div class="px-4 py-3 border-t border-[color:var(--color-line)] flex justify-between items-baseline">
              <span class="text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">Total</span>
              <span class="font-serif text-[18px] tabular-nums font-medium">${Number(quote.total).toLocaleString()}</span>
            </div>
          </div>
        ) : quote.pricing_structure === 'rebate_program' && Array.isArray(quote.rebate_terms) && quote.rebate_terms.length > 0 ? (
          <div class="rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] overflow-hidden">
            <div class="px-4 py-3 border-b border-[color:var(--color-line)] flex justify-between items-baseline">
              <div class="text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">
                Rebate program
              </div>
              {quote.term_months && (
                <span class="text-[11px] font-mono text-[color:var(--color-muted-2)]">{quote.term_months}-month term</span>
              )}
            </div>
            <ul class="divide-y divide-[color:var(--color-line)]">
              {(quote.rebate_terms as any[]).map((rt: any) => (
                <li class="px-4 py-2.5 grid grid-cols-[1fr_140px_1fr] gap-3 items-baseline text-sm">
                  <span class="font-medium">{rt.product}</span>
                  <span class="font-mono tabular-nums text-right">{rt.rebate}</span>
                  <span class="text-[color:var(--color-muted)] text-[12.5px]">{rt.basis}</span>
                </li>
              ))}
            </ul>
          </div>
        ) : quote.pricing_structure === 'time_and_materials' && Array.isArray(quote.tm_rates) && quote.tm_rates.length > 0 ? (
          <div class="rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] overflow-hidden">
            <div class="px-4 py-3 border-b border-[color:var(--color-line)]">
              <div class="text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">Rates &amp; estimate</div>
            </div>
            <ul class="divide-y divide-[color:var(--color-line)]">
              {(quote.tm_rates as any[]).filter((r: any) => r.role && Number(r.rate) > 0).map((r: any) => (
                <li class="px-4 py-2.5 grid grid-cols-[1fr_140px] gap-3 items-baseline text-sm">
                  <span class="font-medium">{r.role}</span>
                  <span class="font-mono tabular-nums text-right">${Number(r.rate).toLocaleString()} / hr</span>
                </li>
              ))}
            </ul>
            {quote.tm_estimate && (quote.tm_estimate as any).hours_high > 0 && (
              <div class="px-4 py-3 border-t border-[color:var(--color-line)] text-[12.5px] text-[color:var(--color-ink-2)] font-serif leading-relaxed">
                <strong class="font-medium">Estimate band:</strong>{' '}
                {(quote.tm_estimate as any).hours_low}–{(quote.tm_estimate as any).hours_high} hrs
                {(quote.tm_estimate as any).materials ? `, + $${Number((quote.tm_estimate as any).materials).toLocaleString()} materials` : ''}.
                T&amp;M billing — actuals invoiced against logged hours.
              </div>
            )}
          </div>
        ) : quote.pricing_structure === 'fixed_price' && lineItems.length > 0 ? (
          <div class="rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] overflow-hidden">
            <div class="px-4 py-3 border-b border-[color:var(--color-line)]">
              <div class="text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">Engagement</div>
            </div>
            <div class="px-4 py-3 font-serif text-[14px] leading-relaxed whitespace-pre-wrap">
              {lineItems[0].description}
            </div>
            <div class="px-4 py-3 border-t border-[color:var(--color-line)] flex justify-between items-baseline">
              <span class="text-eyebrow font-mono uppercase text-[color:var(--color-muted)]">Fee</span>
              <span class="font-serif text-[18px] tabular-nums font-medium">${Number(quote.total).toLocaleString()}</span>
            </div>
          </div>
        ) : Array.isArray(quote.sections_data) && (quote.sections_data as any[]).length > 0 ? (
          <div class="rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] overflow-hidden divide-y divide-[color:var(--color-line)]">
            {(quote.sections_data as any[]).map((s: any) => (
              <div class="px-4 py-3">
                <div class="text-eyebrow font-mono uppercase text-[color:var(--color-muted)] mb-1.5">{s.label}</div>
                {s.kind === 'text' && s.body && (
                  <p class="font-serif text-[14px] leading-relaxed whitespace-pre-wrap text-[color:var(--color-ink-2)]">{s.body}</p>
                )}
                {s.kind === 'bullets' && Array.isArray(s.items) && (
                  <ul class="font-serif text-[14px] leading-relaxed text-[color:var(--color-ink-2)] list-disc pl-5">
                    {s.items.map((it: string) => <li>{it}</li>)}
                  </ul>
                )}
                {s.kind === 'kv_table' && Array.isArray(s.headers) && Array.isArray(s.rows) && s.rows.length > 0 && (
                  <table class="w-full text-[13.5px]">
                    <thead>
                      <tr>{s.headers.map((h: string, i: number) => <th class={`py-1.5 text-[10.5px] font-mono uppercase tracking-wide text-[color:var(--color-muted-2)] ${i > 0 ? 'text-right' : 'text-left'}`}>{h}</th>)}</tr>
                    </thead>
                    <tbody>
                      {s.rows.map((row: any) => (
                        <tr class="border-t border-[color:var(--color-line)]">
                          {s.headers.map((h: string, i: number) => <td class={`py-1.5 ${i > 0 ? 'text-right font-mono tabular-nums' : ''}`}>{row[h] ?? ''}</td>)}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                )}
              </div>
            ))}
          </div>
        ) : (
          <LineItemsTable
            client:load
            quote_id={quote.id}
            initial={lineItems.map((li: any) => ({
              id: li.id,
              position: li.position,
              description: li.description,
              qty: Number(li.qty),
              unit: li.unit,
              unit_price: Number(li.unit_price),
              subtotal: Number(li.subtotal),
              category: li.category,
              confidence: li.confidence,
              margin_pct: li.margin_pct != null ? Number(li.margin_pct) : null,
            }))}
            editable={quote.state === 'DRAFT'}
            total={Number(quote.total)}
            quote_margin_pct={quote.margin_pct != null ? Number(quote.margin_pct) : 0}
          />
        )}
      </div>
    </div>

    <aside class="space-y-6">
      <div class="rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] p-5">
        <h3 class="text-eyebrow font-mono uppercase text-[color:var(--color-muted)] mb-3">Activity</h3>
        {(events ?? []).length === 0 ? (
          <p class="text-sm italic font-serif text-[color:var(--color-muted)]">
            Nothing recorded yet. Brief will let you know when {quote.client_contact_name ?? 'they'} open this.
          </p>
        ) : (
          <ol class="space-y-3">
            {(events ?? []).map((e: any) => (
              <li class="flex items-start gap-3 text-sm">
                <div
                  class="mt-2 w-1.5 h-1.5 rounded-full bg-[color:var(--color-accent)] shrink-0"
                  aria-hidden="true"
                />
                <div class="flex-1 min-w-0">
                  <div>{eventLabels[e.type] ?? e.type}</div>
                  <time
                    datetime={e.created_at}
                    class="text-xs text-[color:var(--color-muted)] mt-0.5 block"
                  >
                    {fmtRelativeDate(e.created_at)}
                  </time>
                </div>
              </li>
            ))}
          </ol>
        )}
      </div>

      <div class="rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] p-5">
        <h3 class="text-eyebrow font-mono uppercase text-[color:var(--color-muted)] mb-3">Messages</h3>
        {(messages ?? []).length === 0 ? (
          <p class="text-sm italic font-serif text-[color:var(--color-muted)]">No messages on this quote yet.</p>
        ) : (
          <ol class="space-y-3">
            {(messages ?? []).map((m: any) => (
              <li class="rounded-lg bg-[color:var(--color-surface-2)] px-3 py-2 text-sm">
                <div class="text-xs text-[color:var(--color-muted)] flex justify-between">
                  <span>{m.direction === 'outbound' ? 'You' : quote.client_contact_name ?? 'Client'}</span>
                  <time datetime={m.created_at}>{fmtRelativeDate(m.created_at)}</time>
                </div>
                {m.subject && <div class="mt-1 font-medium">{m.subject}</div>}
                <div class="mt-1 whitespace-pre-wrap font-serif leading-relaxed text-[color:var(--color-ink-2)]">
                  {m.body}
                </div>
              </li>
            ))}
          </ol>
        )}
      </div>
    </aside>
  </div>

  {/* Hash-driven reply/nudge drawer. Opens when the URL hash is
      #reply or #nudge — wired from the dashboard's "Reply" / "Nudge"
      buttons and the quote's own "Send reminder" / "Reply to client"
      anchor. Idempotent: closing strips the hash. */}
  <QuoteReplyDrawer client:load quote={agendaQuote} inbound={inboundForDrawer} />
</Brief>
