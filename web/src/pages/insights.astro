---
import Base from '@/layouts/Base.astro';
import { client as supabaseClient, getCompanies } from '@/lib/supabase';

export const prerender = false;

const env = Astro.locals.runtime?.env;
const companies = await getCompanies(env);
const companyId = Astro.url.searchParams.get('company_id') ?? companies[0]?.id;

let insights: any[] = [];
if (env && companyId) {
  try {
    const sb = supabaseClient(env, 'anon');
    const { data } = await sb
      .from('intelligence_insights')
      .select('id, category, severity, headline, finding, recommendation, projected_impact, generated_at')
      .eq('company_id', companyId)
      .eq('status', 'open')
      .order('generated_at', { ascending: false })
      .limit(20);
    insights = data ?? [];
  } catch (e) {
    console.warn('insights fetch failed', e);
  }
}

const severityColor: Record<string, string> = {
  critical: 'bg-red-50 text-red-700 border-red-200',
  high:     'bg-orange-50 text-orange-700 border-orange-200',
  medium:   'bg-amber-50 text-amber-700 border-amber-200',
  low:      'bg-blue-50 text-blue-700 border-blue-200',
  info:     'bg-ink-50 text-ink-700 border-ink-200',
};
---

<Base title="Insights · ProService Bid Intelligence">
  <section class="py-6">
    <h1 class="text-3xl font-semibold tracking-tight">
      Operating intelligence
    </h1>
    <p class="mt-2 text-ink-600 max-w-2xl">
      Cross-cutting findings produced by the Intelligence agent — capacity-aware
      pricing recommendations, delivered-margin trends, exclusions
      enforcement signals.
    </p>
  </section>

  <section class="mt-4 space-y-4">
    {insights.length === 0 ? (
      <div class="rounded-md border border-ink-200 bg-white p-8 text-center">
        <p class="text-ink-600">No insights yet. Run the Intelligence agent
        from the API once you have reconciled jobs to analyze.</p>
      </div>
    ) : (
      insights.map((i) => (
        <article class={`rounded-md border p-5 ${severityColor[i.severity] ?? severityColor.info}`}>
          <div class="flex items-center justify-between">
            <div class="text-xs font-medium uppercase tracking-wide">
              {i.category} · {i.severity}
            </div>
            <div class="text-xs text-ink-500">
              {new Date(i.generated_at).toLocaleDateString()}
            </div>
          </div>
          <h3 class="mt-2 font-semibold text-ink-900">{i.headline}</h3>
          <p class="mt-2 text-sm text-ink-700">{i.finding}</p>
          {i.recommendation && (
            <div class="mt-3 rounded bg-white/60 p-3 text-sm">
              <strong class="text-ink-900">Recommendation:</strong>
              {' '}{i.recommendation}
            </div>
          )}
          {i.projected_impact && (
            <div class="mt-2 text-xs text-ink-600">
              Projected impact: {i.projected_impact}
            </div>
          )}
        </article>
      ))
    )}
  </section>
</Base>
