---
import Base from '@/layouts/Base.astro';
import SSRError from '@/components/SSRError.astro';
import { client as supabaseClient, getCompanies } from '@/lib/supabase';
import PostmortemRunner from '@/components/PostmortemRunner';

export const prerender = false;

let renderError: unknown = null;
let companies: Awaited<ReturnType<typeof getCompanies>> = [];
let companyId: string | undefined;
let lostBids: any[] = [];

try {
  const env = Astro.locals.runtime?.env;
  companies = await getCompanies(env);
  companyId = Astro.url.searchParams.get('company_id') ?? companies[0]?.id;
  if (env && companyId) {
    const sb = supabaseClient(env, 'service');
    const { data, error } = await sb
      .from('bids')
      .select('id, client_name, service_line, estimated_value, outcome_competitor, outcome_winning_bid, outcome_captured_at')
      .eq('company_id', companyId)
      .eq('outcome', 'LOST')
      .order('outcome_captured_at', { ascending: false })
      .limit(50);
    if (error) throw error;
    lostBids = data ?? [];
  }
} catch (e) {
  renderError = e;
}
---

<Base title="Loss postmortem · ProService Bid Intelligence">
  {renderError && <SSRError page="/postmortem" error={renderError} />}
  <section class="py-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-semibold tracking-tight">Loss postmortem</h1>
        <p class="mt-2 text-ink-600 max-w-2xl">
          9th agent (extension of Intelligence). Pick a LOST bid; the agent
          reads our pricing, the competitor's price, and recent comparable
          losses, then produces a structured reasons-why + next-bid
          recommendations.
        </p>
      </div>
      <select
        class="rounded-md border border-ink-300 bg-white px-3 py-1.5 text-sm"
        onchange="window.location.search = `?company_id=${this.value}`"
      >
        {companies.map((c) => (
          <option value={c.id} selected={c.id === companyId}>
            {c.name}
          </option>
        ))}
      </select>
    </div>
  </section>

  {lostBids.length === 0 ? (
    <div class="rounded-md border border-ink-200 bg-white p-8 text-center">
      <p class="text-ink-600">
        No LOST bids yet for this company. Mark a SENT bid as LOST (from the
        Bids page) to unlock the postmortem agent.
      </p>
    </div>
  ) : (
    <PostmortemRunner client:load lostBids={lostBids} />
  )}
</Base>
