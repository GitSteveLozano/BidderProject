---
import Base from '@/layouts/Base.astro';
import SSRError from '@/components/SSRError.astro';
import BidGenerator from '@/components/BidGenerator';
import { getCompanies, getServiceLines } from '@/lib/supabase';

// `prerender = false` MUST appear before any await so the Astro
// hybrid build classifies this route as SSR (otherwise it's
// prerendered at build time and Astro.locals.runtime is undefined).
export const prerender = false;

let renderError: unknown = null;
let companies: Awaited<ReturnType<typeof getCompanies>> = [];
let serviceLines: Awaited<ReturnType<typeof getServiceLines>> = [];

try {
  const env = Astro.locals.runtime?.env;
  companies = await getCompanies(env);
  const defaultCompanyId = companies[0]?.id;
  serviceLines = defaultCompanyId
    ? await getServiceLines(defaultCompanyId, env)
    : [];
} catch (e) {
  renderError = e;
}
---

<Base title="Generate a bid · ProService Bid Intelligence">
  <section class="py-6">
    <h1 class="text-3xl font-semibold tracking-tight">Generate a bid</h1>
    <p class="mt-2 text-ink-600 max-w-2xl">
      Fill in the scope and labor plan. All 4 generation agents fire in
      sequence — Intake parses your scope, Context loads the company
      profile, Pricing queries real loaded labor data, and Composition
      writes the bid in voice with exclusions verified.
    </p>
  </section>

  {renderError ? (
    <SSRError page="/generate" error={renderError} />
  ) : (
    <BidGenerator
      client:load
      companies={companies}
      serviceLines={serviceLines}
    />
  )}
</Base>
