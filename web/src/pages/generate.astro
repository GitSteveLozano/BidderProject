---
import Brief from '@/layouts/Brief.astro';
import QuoteProduction from '@/components/quote-production/QuoteProduction';
import { client as supabaseService } from '@/lib/supabase';

export const prerender = false;
Astro.response.headers.set('cache-control', 'no-store, no-cache, must-revalidate, max-age=0');
Astro.response.headers.set('cdn-cache-control', 'no-store');

const env = Astro.locals.runtime?.env;
const user = Astro.locals.user;
const membership = Astro.locals.membership;
if (!user || !membership || !env) {
  return Astro.redirect('/auth/signin?next=/generate');
}

const svc = supabaseService(env, 'service');
const { data: shop } = await svc
  .from('shops')
  .select('legal_name, trade_name, license_number, license_jurisdiction, default_markup_pct, default_labor_rate, voice_profile, owner_name, data_state')
  .eq('id', membership.shop_id)
  .maybeSingle();

const shopLabel = shop?.trade_name || shop?.legal_name || 'My shop';
const ownerFirst = (shop?.owner_name ?? user.name ?? user.email ?? '').split(' ')[0];

const shopContext = {
  legal_name: shop?.legal_name ?? '',
  trade_name: shop?.trade_name ?? undefined,
  license_number: shop?.license_number ?? undefined,
  license_jurisdiction: shop?.license_jurisdiction ?? undefined,
  boilerplate_intro: shop?.voice_profile?.boilerplate_intro ?? undefined,
  boilerplate_closing: shop?.voice_profile?.boilerplate_closing ?? undefined,
  default_markup_pct: Number(shop?.default_markup_pct ?? 32),
  default_labor_rate: Number(shop?.default_labor_rate ?? 92),
};
---

<Brief
  title="New quote"
  active="newquote"
  shopLabel={shopLabel}
  shopInitial={shopLabel.charAt(0).toUpperCase()}
  ownerFirst={ownerFirst}
  ownerRole={membership.role.charAt(0).toUpperCase() + membership.role.slice(1)}
  dataState={shop?.data_state ?? 'cold-start'}
>
  <QuoteProduction client:load shop={shopContext} />
</Brief>
