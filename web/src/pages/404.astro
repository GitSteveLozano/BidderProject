---
import Base from '@/layouts/Base.astro';
---

<Base title="Not found · ProService Bid Intelligence">
  <section class="py-20 text-center">
    <div class="text-6xl font-semibold tracking-tight text-ink-300">404</div>
    <h1 class="mt-4 text-2xl font-semibold tracking-tight">Page not found</h1>
    <p class="mt-2 text-ink-600">
      The page you requested doesn't exist (yet).
    </p>
    <div class="mt-6 flex justify-center gap-3">
      <a
        href="/"
        class="rounded-md bg-accent-600 px-5 py-2.5 text-white font-medium hover:bg-accent-700"
      >
        Back to home
      </a>
      <a
        href="/generate"
        class="rounded-md border border-ink-300 bg-white px-5 py-2.5 font-medium hover:bg-ink-100"
      >
        Generate a bid
      </a>
    </div>
  </section>
</Base>
