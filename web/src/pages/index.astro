---
import Base from '@/layouts/Base.astro';
---

<Base title="Brief">
  <!-- Hero -->
  <section class="py-12 sm:py-20">
    <div class="max-w-3xl">
      <span class="inline-flex items-center gap-2 rounded-full bg-accent-50 px-3 py-1 text-xs font-medium text-accent-700">
        <span class="size-2 rounded-full bg-accent-500"></span>
        9 specialized agents · tool-grounded numerics · payroll-integrated
      </span>
      <h1 class="mt-4 text-4xl sm:text-5xl font-semibold tracking-tight text-ink-900">
        Bid generation, capacity-aware pricing,
        <span class="text-accent-600">job-cost reconciliation.</span>
      </h1>
      <p class="mt-4 text-lg text-ink-600">
        Multi-agent AI platform for SMB specialty contractors. Eight specialized
        agents coordinate over a shared context store. Pricing tools query real
        loaded labor data — they never generate numbers. Every reconciled job
        compounds the margin profile that feeds the next bid.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/generate"
          class="inline-flex items-center gap-2 rounded-md bg-accent-600 px-5 py-2.5 text-white font-medium hover:bg-accent-700"
        >
          Generate a bid →
        </a>
        <a
          href="/bids"
          class="inline-flex items-center gap-2 rounded-md border border-ink-300 bg-white px-5 py-2.5 font-medium hover:bg-ink-100"
        >
          Browse seeded bids
        </a>
        <a
          href="https://github.com/GitSteveLozano/BidderProject/blob/main/docs/brief.md"
          target="_blank"
          class="inline-flex items-center gap-2 rounded-md border border-ink-300 bg-white px-5 py-2.5 font-medium hover:bg-ink-100"
        >
          Read the brief
        </a>
      </div>
    </div>
  </section>

  <!-- The 5 layers -->
  <section class="py-12 border-t border-ink-200">
    <h2 class="text-2xl font-semibold tracking-tight">The five layers</h2>
    <p class="mt-2 text-ink-600">Each owns a specific subset of the eight agents.</p>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
      {[
        { n: 1, title: 'Contextual Onboarding', body: 'Voice, service lines, exclusions templates extracted from past quotes.', agents: 'Intake · Context' },
        { n: 2, title: 'Bid Generation', body: 'Scope → polished bid in voice with tool-grounded pricing.', agents: 'Intake · Context · Pricing · Composition' },
        { n: 3, title: 'Follow-up', body: 'Segment-aware cadence: single soft touch (repeat) or 3-touch (cold).', agents: 'Follow-up' },
        { n: 4, title: 'Job-Cost Reconciliation', body: 'Quoted vs delivered margin via ProService payroll integration.', agents: 'JCR' },
        { n: 5, title: 'Operating Intelligence', body: 'Capacity-aware synthesis across the corpus, async + batched.', agents: 'Intelligence (meta)' },
      ].map(({ n, title, body, agents }) => (
        <div class="rounded-lg border border-ink-200 bg-white p-5">
          <div class="flex items-center gap-2 text-sm font-medium text-accent-600">
            Layer {n}
          </div>
          <div class="mt-1 font-semibold text-ink-900">{title}</div>
          <p class="mt-2 text-sm text-ink-600">{body}</p>
          <div class="mt-3 text-xs font-mono text-ink-500">{agents}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Why not a GPT wrapper -->
  <section class="py-12 border-t border-ink-200">
    <h2 class="text-2xl font-semibold tracking-tight">
      Why this is <em>not</em> a GPT wrapper
    </h2>
    <div class="mt-6 grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-ink-200 bg-white p-5">
        <h3 class="font-semibold">Specialization</h3>
        <p class="mt-2 text-sm text-ink-600">
          Routing + extraction on Haiku 4.5. Synthesis on Sonnet 4.6.
          Each agent uses the model best suited to its task.
        </p>
      </div>
      <div class="rounded-lg border border-ink-200 bg-white p-5">
        <h3 class="font-semibold">Tool-grounded numerics</h3>
        <p class="mt-2 text-sm text-ink-600">
          Pricing never <em>generates</em> labor cost. It calls
          <code class="bg-ink-100 px-1 rounded text-xs">get_loaded_labor_cost(trade, hours)</code>
          which returns real burdened payroll data.
        </p>
      </div>
      <div class="rounded-lg border border-ink-200 bg-white p-5">
        <h3 class="font-semibold">Closed-loop intelligence</h3>
        <p class="mt-2 text-sm text-ink-600">
          Every reconciled job updates the margin profile that feeds the next
          bid. Only ProService has this — no PEO substitute exists.
        </p>
      </div>
    </div>
  </section>
</Base>
