---
import Base from '@/layouts/Base.astro';
import { googleSignInUrl } from '@/lib/auth';

export const prerender = false;

Astro.response.headers.set('cache-control', 'no-store');

const env = Astro.locals.runtime?.env;
const next = Astro.url.searchParams.get('next') ?? '/dashboard';
const error = Astro.url.searchParams.get('error');
// When the user clicks "Connect Calendar" from Settings we route through
// signin again to upgrade their grant. The next= param sends them back
// to where they started.
const withCalendar = Astro.url.searchParams.get('with_calendar') === '1';

const redirectTo = `${Astro.url.origin}/auth/callback?next=${encodeURIComponent(next)}`;
const googleUrl = env ? googleSignInUrl(env, redirectTo, { withCalendar }) : '#';

// If already signed in AND we're not trying to add a scope, skip the screen.
if (Astro.locals.user && !withCalendar) {
  return Astro.redirect(next);
}
---

<Base title="Sign in">
  <section class="mx-auto max-w-md py-16 px-4">
    <div class="text-center mb-8">
      <div class="text-eyebrow font-mono uppercase text-[color:var(--color-muted-2)] mb-2">
        Welcome
      </div>
      <h1 class="font-serif text-[40px] font-medium leading-tight">
        Sign in to Brief.
      </h1>
      <p class="mt-3 text-sm text-[color:var(--color-muted)] leading-relaxed">
        Brief uses your Google account for sign-in only. Nothing else is read until you connect things yourself.
      </p>
    </div>

    {error && (
      <div class="mb-4 rounded-lg border border-[color:var(--color-line)] bg-[color:var(--color-danger-tint)] px-4 py-3 text-sm text-[color:var(--color-danger)]">
        Sign-in didn't complete. {decodeURIComponent(error)}
      </div>
    )}

    <div class="rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface)] p-8 shadow-[var(--shadow-sm)]">
      <a
        href={googleUrl}
        class="inline-flex items-center justify-center gap-2.5 w-full px-5 py-3 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-line-2)] hover:bg-[color:var(--color-surface-2)] hover:border-[color:var(--color-line-strong)] font-medium text-[14px] text-[color:var(--color-ink)] transition-colors"
        aria-label="Continue with Google"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
          <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/>
          <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/>
          <path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/>
          <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z"/>
        </svg>
        Continue with Google
      </a>
      <p class="mt-4 text-xs text-[color:var(--color-muted)] leading-relaxed">
        We'll also ask for Google Calendar permission so Brief can suggest the best time to send a follow-up.
        You can decline that and still use everything else.
      </p>
    </div>

    <p class="mt-6 text-center text-xs text-[color:var(--color-muted)]">
      By signing in you agree to Brief's terms. We don't share your data.
    </p>
  </section>
</Base>
