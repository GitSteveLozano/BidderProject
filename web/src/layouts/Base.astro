---
/**
 * Base — bare layout for routes that don't get the Brief chrome
 * (landing, auth, onboarding, error pages). The Brief.astro layout
 * is used for everything else.
 *
 * Existing /bids, /jcr, /insights, /generate, /postmortem pages
 * still wear this Base layout. They get migrated to Brief.astro in
 * their respective redesign PRs (4-6).
 */
import '@/styles/tokens.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Brief',
  description = 'Bid production and pipeline operations for finishing-trade contractors.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full" data-theme="paper">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Brief</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body
    class="min-h-full bg-[color:var(--color-bg)] text-[color:var(--color-ink)] font-sans antialiased"
  >
    <header class="border-b border-[color:var(--color-line)] bg-[color:var(--color-surface)]">
      <div class="mx-auto max-w-7xl px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5">
          <div
            class="w-7 h-7 rounded-md bg-[color:var(--color-ink)] text-[color:var(--color-bg)] grid place-items-center font-serif italic font-semibold text-[16px] leading-none"
          >B</div>
          <span class="font-serif text-[20px] font-medium leading-none tracking-tight">
            Brief
          </span>
        </a>
        <nav class="flex items-center gap-5 text-[13px]">
          <a href="/generate" class="hover:text-[color:var(--color-accent)]">Generate</a>
          <a href="/bids" class="hover:text-[color:var(--color-accent)]">Quotes</a>
          <a href="/jcr" class="hover:text-[color:var(--color-accent)]">Jobs</a>
          <a href="/insights" class="hover:text-[color:var(--color-accent)]">Dashboard</a>
          <a
            href="https://github.com/GitSteveLozano/BidderProject"
            target="_blank"
            rel="noopener"
            class="text-[color:var(--color-muted)] hover:text-[color:var(--color-ink)]"
          >GitHub</a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-[color:var(--color-line)] mt-16">
      <div
        class="mx-auto max-w-7xl px-4 py-6 text-[13px] text-[color:var(--color-muted)] flex flex-wrap justify-between gap-2"
      >
        <span class="font-mono">Brief proposes; you decide.</span>
        <span class="font-mono text-[color:var(--color-muted-2)]">v1.0</span>
      </div>
    </footer>

    <style is:global>
      @keyframes slide-in-right {
        from { transform: translateX(8%); opacity: 0; }
        to   { transform: translateX(0);  opacity: 1; }
      }
    </style>
  </body>
</html>
