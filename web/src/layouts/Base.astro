---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ProService Bid Intelligence',
  description = 'Multi-agent AI platform for SMB specialty contractors',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-full bg-ink-50 text-ink-900 antialiased font-sans">
    <header class="border-b border-ink-200 bg-white">
      <div class="mx-auto max-w-7xl px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2">
          <span class="text-lg font-semibold tracking-tight">
            ProService Bid Intelligence
          </span>
        </a>
        <nav class="flex items-center gap-6 text-sm">
          <a href="/generate" class="hover:text-accent-600">Generate bid</a>
          <a href="/bids" class="hover:text-accent-600">Bids</a>
          <a href="/insights" class="hover:text-accent-600">Insights</a>
          <a
            href="https://github.com/GitSteveLozano/BidderProject"
            target="_blank"
            rel="noopener"
            class="text-ink-500 hover:text-ink-700"
          >
            GitHub
          </a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-ink-200 mt-16">
      <div class="mx-auto max-w-7xl px-4 py-6 text-sm text-ink-500 flex flex-wrap justify-between gap-2">
        <span>
          Built on Astro + Cloudflare Pages. Open source —
          <a
            href="https://github.com/GitSteveLozano/BidderProject"
            class="underline hover:text-ink-700"
          >
            source on GitHub
          </a>.
        </span>
        <span>
          <code class="text-xs bg-ink-100 px-2 py-1 rounded">
            claude-sonnet-4-6
          </code>
          {' '}+{' '}
          <code class="text-xs bg-ink-100 px-2 py-1 rounded">
            claude-haiku-4-5
          </code>
        </span>
      </div>
    </footer>
  </body>
</html>
