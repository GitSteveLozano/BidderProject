---
/**
 * Brief — chromed layout (sidebar + topbar). Used by every authed
 * page; landing/auth/onboarding use BareLayout.
 *
 * Sidebar matches design/snapshots/dashboard.jsx + the mockups under
 * design/mockups/. Calibration footer renders the current data_state
 * ("Cold start", "Calibrating", "Calibrated") — passed in from the
 * .astro page that loads the shop.
 */
import '@/styles/tokens.css';

interface Props {
  title?: string;
  description?: string;
  /** Active nav item — drives the sidebar highlight + topbar crumb. */
  active?: 'dashboard' | 'projects' | 'quotes' | 'jobs' | 'clients' | 'settings' | 'newquote' | 'quotedetail';
  /** Shop label rendered in the topbar crumb. */
  shopLabel?: string;
  /** Shop avatar initial + owner role for the sidebar shop chip. */
  shopInitial?: string;
  ownerFirst?: string;
  ownerRole?: string;
  /** Calibration footer state. */
  dataState?: 'cold-start' | 'calibrating' | 'calibrated';
  calibrationSub?: string;
  /** Badge counts on the active-quotes / live-jobs nav items. */
  activeQuotes?: number;
  liveJobs?: number;
}

const {
  title = 'Brief',
  description = 'Bid production and pipeline operations for finishing-trade contractors.',
  active = 'dashboard',
  shopLabel = 'L·A Stucco',
  shopInitial = 'L',
  ownerFirst = 'Cavy',
  ownerRole = 'Owner',
  dataState = 'calibrated',
  calibrationSub,
  activeQuotes,
  liveJobs,
} = Astro.props;

const CRUMB: Record<NonNullable<Props['active']>, string> = {
  dashboard: 'Dashboard',
  projects: 'Projects',
  quotes: 'Quotes',
  jobs: 'Jobs',
  clients: 'Clients',
  settings: 'Settings',
  newquote: 'New quote',
  quotedetail: 'Quote',
};

const CALIB: Record<NonNullable<Props['dataState']>, { label: string; sub: string }> = {
  // Copy matches design/mockups (01-list-detail.png "New / 0 sent so far",
  // 01-default.png "Calibrating / learning from your first quotes",
  // 01-zones.png "Calibrated / learned from 30+ quotes").
  'cold-start': { label: 'New', sub: '0 sent so far' },
  calibrating: { label: 'Calibrating', sub: 'learning from your first quotes' },
  calibrated: { label: 'Calibrated', sub: 'learned from 30+ quotes' },
};

const calib = CALIB[dataState];
const calibSub = calibrationSub ?? calib.sub;

const navClass = (key: Props['active']) =>
  `flex items-center gap-2.5 px-2.5 py-[7px] rounded-md text-[13px] transition-colors ` +
  (active === key
    ? 'bg-[color:var(--color-surface)] text-[color:var(--color-ink)] font-medium shadow-[var(--shadow-sm)]'
    : 'text-[color:var(--color-ink-2)] hover:bg-[color:var(--color-surface)]');
---

<!doctype html>
<html lang="en" class="h-full" data-theme="paper">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Brief</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {/* Apply stored theme synchronously before paint — avoids FOWT */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('brief-theme');
          if (t === 'site' || t === 'paper') {
            document.documentElement.setAttribute('data-theme', t);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body
    class="min-h-full bg-[color:var(--color-bg)] text-[color:var(--color-ink)] font-sans"
  >
    <div class="grid md:grid-cols-[252px_1fr] grid-cols-1 md:h-screen min-h-screen">
      <!-- Sidebar (collapses to bottom tab bar < md) -->
      <aside
        class="hidden md:flex bg-[color:var(--color-bg-2)] border-r border-[color:var(--color-line)] p-4 flex-col gap-3 min-h-0"
        aria-label="Primary navigation"
      >
        <div class="flex items-center gap-2.5 px-1 pb-3">
          <div
            class="w-7 h-7 rounded-md bg-[color:var(--color-ink)] text-[color:var(--color-bg)] flex items-center justify-center font-serif italic font-semibold text-[16px] leading-none"
          >
            B
          </div>
          <div class="font-serif text-[20px] font-medium leading-none tracking-tight">
            Brief
          </div>
        </div>

        <div
          class="flex items-center gap-2.5 p-2.5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-line)]"
        >
          <div
            class="w-8 h-8 rounded-md bg-[color:var(--color-accent)] text-[color:var(--color-accent-ink)] grid place-items-center font-serif font-semibold text-[16px]"
          >
            {shopInitial}
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-medium text-[13px] truncate">{shopLabel}</div>
            <div class="text-[11px] text-[color:var(--color-muted)] mt-px">
              {ownerFirst} · {ownerRole}
            </div>
          </div>
        </div>

        <a
          href="/generate"
          class="inline-flex items-center justify-center gap-1.5 w-full px-3 py-2.5 rounded-lg bg-[color:var(--color-accent)] text-[color:var(--color-accent-ink)] font-medium text-[13px] hover:brightness-95"
        >
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true"><path d="M7 2.5v9M2.5 7h9" /></svg>
          New quote
        </a>

        <nav class="flex flex-col gap-px mt-2">
          <a href="/dashboard" class={navClass('dashboard')}>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
              <rect x="2" y="2" width="4" height="4" rx="0.6" />
              <rect x="8" y="2" width="4" height="4" rx="0.6" />
              <rect x="2" y="8" width="4" height="4" rx="0.6" />
              <rect x="8" y="8" width="4" height="4" rx="0.6" />
            </svg>
            <span>Dashboard</span>
          </a>
          <a href="/projects" class={navClass('projects')}>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" aria-hidden="true">
              <path d="M1.5 4a0.5 0.5 0 0 1 0.5 -0.5h3.2l1.3 1.3h6a0.5 0.5 0 0 1 0.5 0.5v6.2a0.5 0.5 0 0 1 -0.5 0.5h-10.5a0.5 0.5 0 0 1 -0.5 -0.5z" />
            </svg>
            <span>Projects</span>
          </a>
          <a href="/quotes" class={navClass('quotes')}>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 1.5h5l3 3v8a0.5 0.5 0 0 1 -0.5 0.5h-7.5a0.5 0.5 0 0 1 -0.5 -0.5v-10.5a0.5 0.5 0 0 1 0.5 -0.5z" />
              <path d="M8 1.5v3h3" />
              <path d="M5 7h4M5 9.5h4" stroke-linecap="round" />
            </svg>
            <span>Quotes</span>
            {activeQuotes !== undefined && activeQuotes > 0 && (
              <span class="ml-auto font-mono text-[11px] bg-[color:var(--color-line-2)] text-[color:var(--color-ink-2)] px-1.5 rounded">
                {activeQuotes}
              </span>
            )}
          </a>
          <a href="/jobs" class={navClass('jobs')}>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" aria-hidden="true">
              <path d="M2 6.5l5-4 5 4v5.5a0.5 0.5 0 0 1 -0.5 0.5h-9a0.5 0.5 0 0 1 -0.5 -0.5z" />
              <path d="M5.5 12.5v-3.5h3v3.5" />
            </svg>
            <span>Jobs</span>
            {liveJobs !== undefined && liveJobs > 0 && (
              <span class="ml-auto font-mono text-[11px] bg-[color:var(--color-line-2)] text-[color:var(--color-ink-2)] px-1.5 rounded">
                {liveJobs}
              </span>
            )}
          </a>
          <a href="/clients" class={navClass('clients')}>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
              <circle cx="7" cy="5" r="2.4" />
              <path d="M2.5 12c0-2.2 2-3.6 4.5-3.6s4.5 1.4 4.5 3.6" stroke-linecap="round" />
            </svg>
            <span>Clients</span>
          </a>
        </nav>

        <div class="text-eyebrow font-mono text-[color:var(--color-muted-2)] px-2.5 pt-3 pb-1 font-medium">
          Account
        </div>
        <nav class="flex flex-col gap-px">
          <a href="/settings" class={navClass('settings')}>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
              <circle cx="7" cy="7" r="2" />
              <path d="M7 1.5v1.8M7 10.7v1.8M1.5 7h1.8M10.7 7h1.8M3.1 3.1l1.3 1.3M9.6 9.6l1.3 1.3M3.1 10.9l1.3 -1.3M9.6 4.4l1.3 -1.3" stroke-linecap="round" />
            </svg>
            <span>Settings</span>
          </a>
        </nav>

        <div
          class="mt-auto pt-3.5 border-t border-[color:var(--color-line)]"
        >
          <div class="font-medium text-[13px]">{calib.label}</div>
          <div class="text-[12px] text-[color:var(--color-muted)] mt-0.5 leading-snug">
            {calibSub}
          </div>
          <div class="text-[11px] font-mono text-[color:var(--color-muted-2)] mt-3 leading-snug">
            Brief proposes; you decide.
          </div>
        </div>
      </aside>

      <!-- Main column -->
      <div class="flex flex-col min-w-0 md:overflow-hidden">
        <div
          class="flex items-center gap-3.5 px-4 md:px-10 py-3.5 border-b border-[color:var(--color-line)] bg-[color:var(--color-bg)]"
        >
          <a
            href="/"
            class="md:hidden flex items-center gap-2 mr-2"
            aria-label="Brief home"
          >
            <div class="w-7 h-7 rounded-md bg-[color:var(--color-ink)] text-[color:var(--color-bg)] grid place-items-center font-serif italic font-semibold text-[14px] leading-none">B</div>
          </a>
          <div class="flex items-center gap-2 text-[13px] text-[color:var(--color-muted)] min-w-0">
            <span class="truncate hidden sm:inline">{shopLabel}</span>
            <span class="text-[color:var(--color-muted-2)] hidden sm:inline">/</span>
            <span class="text-[color:var(--color-ink)] font-medium truncate">{CRUMB[active]}</span>
          </div>
          <div class="flex-1" />
          <div class="hidden md:flex items-center gap-2">
            <slot name="topbar-actions" />
          </div>
          <div
            class="hidden md:flex items-center gap-2 px-2.5 py-1.5 rounded-lg bg-[color:var(--color-surface)] border border-[color:var(--color-line)] w-[320px]"
          >
            <span class="text-[color:var(--color-muted)]" aria-hidden="true">⌕</span>
            <input
              type="search"
              placeholder="Search quotes, clients, jobs…"
              class="flex-1 bg-transparent border-0 outline-none text-[13px]"
              aria-label="Search"
            />
            <span class="font-mono text-[11px] text-[color:var(--color-muted-2)] border border-[color:var(--color-line)] rounded px-1">⌘K</span>
          </div>
        </div>

        <main class="flex-1 md:overflow-auto px-4 md:px-10 py-7 pb-24 md:pb-7">
          <slot />
        </main>
      </div>
    </div>

    {/* Mobile bottom tab bar */}
    <nav
      class="md:hidden fixed bottom-0 inset-x-0 z-40 bg-[color:var(--color-surface)] border-t border-[color:var(--color-line)] flex items-stretch shadow-[var(--shadow-md)]"
      aria-label="Primary navigation"
    >
      <a href="/dashboard" class={`flex-1 flex flex-col items-center gap-0.5 py-2.5 text-[11px] font-mono ${active === 'dashboard' ? 'text-[color:var(--color-accent)]' : 'text-[color:var(--color-muted)]'}`}>
        <span aria-hidden="true">▣</span><span>Dash</span>
      </a>
      <a href="/quotes" class={`flex-1 flex flex-col items-center gap-0.5 py-2.5 text-[11px] font-mono ${active === 'quotes' || active === 'quotedetail' ? 'text-[color:var(--color-accent)]' : 'text-[color:var(--color-muted)]'}`}>
        <span aria-hidden="true">📄</span><span>Quotes</span>
      </a>
      <a href="/generate" class="flex-1 flex flex-col items-center gap-0.5 py-2.5 text-[11px] font-mono text-[color:var(--color-accent-ink)] bg-[color:var(--color-accent)] -my-px font-semibold" aria-label="New quote">
        <span aria-hidden="true">+</span><span>New</span>
      </a>
      <a href="/jobs" class={`flex-1 flex flex-col items-center gap-0.5 py-2.5 text-[11px] font-mono ${active === 'jobs' ? 'text-[color:var(--color-accent)]' : 'text-[color:var(--color-muted)]'}`}>
        <span aria-hidden="true">⌂</span><span>Jobs</span>
      </a>
      <a href="/settings" class={`flex-1 flex flex-col items-center gap-0.5 py-2.5 text-[11px] font-mono ${active === 'settings' ? 'text-[color:var(--color-accent)]' : 'text-[color:var(--color-muted)]'}`}>
        <span aria-hidden="true">⚙</span><span>More</span>
      </a>
    </nav>
  </body>
</html>

<style is:global>
  @keyframes slide-in-right {
    from { transform: translateX(8%); opacity: 0; }
    to   { transform: translateX(0);  opacity: 1; }
  }
</style>
