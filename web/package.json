{
  "name": "proservice-bid-intelligence-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Custom SPA for ProService Bid Intelligence — Astro + Cloudflare Pages + Workers",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/patch-cf-streaming.mjs",
    "preview": "wrangler pages dev ./dist --port 4321 --compatibility-date 2026-01-01 --compatibility-flags=nodejs_compat",
    "deploy": "npm run build && wrangler pages deploy ./dist --project-name=proservice-bid-intelligence --commit-dirty=true",
    "typecheck": "astro check && tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@astrojs/check": "^0.9.4",
    "@astrojs/cloudflare": "^11.2.0",
    "@astrojs/solid-js": "^4.4.4",
    "@astrojs/tailwind": "^5.1.4",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource/newsreader": "^5.2.10",
    "@supabase/supabase-js": "^2.46.0",
    "astro": "^4.16.18",
    "solid-js": "^1.9.3",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "wrangler": "^3.95.0"
  }
}
