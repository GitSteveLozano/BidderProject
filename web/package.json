{
  "name": "proservice-bid-intelligence-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Custom SPA for ProService Bid Intelligence — Astro + Cloudflare Pages + Workers",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler pages dev ./dist --port 4321 --compatibility-date 2026-01-01",
    "deploy": "astro build && wrangler pages deploy ./dist",
    "typecheck": "astro check && tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/cloudflare": "^11.2.0",
    "@astrojs/solid-js": "^4.4.4",
    "@astrojs/tailwind": "^5.1.4",
    "@anthropic-ai/sdk": "^0.40.0",
    "@supabase/supabase-js": "^2.46.0",
    "astro": "^4.16.18",
    "solid-js": "^1.9.3",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "wrangler": "^3.95.0"
  }
}
