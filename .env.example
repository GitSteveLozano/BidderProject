# Copy to .env and fill in real values. Do NOT commit .env.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides. Defaults are set in core/models.py.
# MODEL_HAIKU=claude-haiku-4-5
# MODEL_SONNET=claude-sonnet-4-6
# MODEL_OPUS=claude-opus-4-7

# --- OpenAI (for embeddings only — text-embedding-3-small) ---
# Spec uses OpenAI embeddings because pgvector + 1536-dim is the path of
# least resistance. Swap to Voyage AI if preferred.
OPENAI_API_KEY=sk-...

# --- Postgres + pgvector ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bidintel

# --- Object storage ---
# Local dev: leave blank, files saved to ./data/processed/uploads.
# Prod: s3://bucket-name
S3_BUCKET=

# --- Redis (for Celery scheduled tasks) ---
REDIS_URL=redis://localhost:6379/0

# --- Demo flags ---
DEMO_MODE=true
DEMO_COMPANY_ID=00000000-0000-0000-0000-000000000001

# When true, the orchestrator uses the real Anthropic tool-use Pricing
# variant (agents/pricing_tool_use.py) — Claude itself chooses which
# tools to call. Stronger demo angle but adds ~5-10s and an API call.
# Default false uses the deterministic-Python variant.
USE_TOOL_USE_PRICING=false

# When true, the weekly Intelligence task logs that batch mode is on.
# The narrative-batching helper lives at
# core.batch.batch_intelligence_narratives (50% cheaper, async via the
# Anthropic Batch API). Exercise with `python cli.py batch-smoke`.
INTELLIGENCE_USE_BATCH=false

# --- Webhook signing ---
# HMAC-SHA256 shared secret for the payroll webhook (spec Phase 2). If
# unset, the receiver accepts unsigned requests with a warning — DO NOT
# leave unset in production.
PAYROLL_WEBHOOK_SECRET=

# --- Logging ---
LOG_LEVEL=INFO
