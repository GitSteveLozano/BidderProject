# Copy to .streamlit/secrets.toml for local testing of the Streamlit
# Cloud bootstrap path. Do NOT commit secrets.toml — it's gitignored.
#
# On Streamlit Cloud: paste the same TOML into Settings → Secrets.
# The streamlit_app.py shim promotes each key to an env var, so
# core/settings.py (pydantic-settings) picks them up.

ANTHROPIC_API_KEY = "sk-ant-..."
OPENAI_API_KEY    = "sk-..."

# Supabase connection string (Settings → Database → Connection string):
#   postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Use the "Session" pooler endpoint, not "Transaction" — psycopg pool
# expects a long-lived connection.
DATABASE_URL = "postgresql://postgres.PROJECT:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# When true (default), streamlit_app.py auto-applies schema + runs
# db.seed_all on first boot against an empty database. Set to false
# once you've curated company data and don't want the boot path to
# clobber it.
AUTO_SEED = "true"

# Tool-use Pricing variant (real anthropic.tools= loop). Slightly
# slower per bid but stronger demo angle.
USE_TOOL_USE_PRICING = "false"

# Demo company id (Honolulu Stucco & Exteriors LLC — seeded by default)
DEMO_COMPANY_ID = "00000000-0000-0000-0000-000000000001"
